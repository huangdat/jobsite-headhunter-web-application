{
  "info": {
    "name": "Job-02 Job APIs",
    "_postman_id": "b0c9d9d5-4c3b-4b5f-8c6a-7d0f0b3e7f6a",
    "description": "Collection for job list/search/filter, job detail, and saved jobs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081/headhunt"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "jobId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "List Jobs (Paging)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/jobs?page=1&size=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "jobs"],
          "query": [
            {"key": "page", "value": "1"},
            {"key": "size", "value": "10"}
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Search + Filter Jobs (Keyword + Location + WorkingType + Salary)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/jobs?page=1&size=10&keyword=java&location=Ho%20Chi%20Minh&workingType=REMOTE&salaryMin=1000&salaryMax=3000&rankLevel=JUNIOR",
          "host": ["{{baseUrl}}"],
          "path": ["api", "jobs"],
          "query": [
            {"key": "page", "value": "1"},
            {"key": "size", "value": "10"},
            {"key": "keyword", "value": "java"},
            {"key": "location", "value": "Ho Chi Minh"},
            {"key": "workingType", "value": "REMOTE"},
            {"key": "salaryMin", "value": "1000"},
            {"key": "salaryMax", "value": "3000"},
            {"key": "rankLevel", "value": "JUNIOR"}
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Best Jobs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/jobs/best?size=6",
          "host": ["{{baseUrl}}"],
          "path": ["api", "jobs", "best"],
          "query": [
            {"key": "size", "value": "6"}
